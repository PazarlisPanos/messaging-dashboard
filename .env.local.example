# === DATABASE ===
# PostgreSQL connection string for this client's database
DATABASE_URL=postgresql://user:password@localhost:5432/client_db

# === AUTH ===
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://dashboard.yourdomain.com

# Dashboard login credentials (simple MVP auth)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-in-production

# === n8n ===
# Base URL of your n8n instance
N8N_BASE_URL=https://n8n.yourdomain.com
# Webhook path for WhatsApp manual reply
N8N_WA_REPLY_WEBHOOK=/webhook/wa-manual-reply
# Webhook path for Viber manual reply (add when ready)
N8N_VB_REPLY_WEBHOOK=/webhook/vb-manual-reply
# Optional: shared secret for n8n webhook auth
N8N_WEBHOOK_SECRET=your-n8n-secret
